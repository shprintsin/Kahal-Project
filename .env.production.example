# =====================================================================
# Production env vars for docker-compose.production.yml (the main app).
# Copy this file to .env.production on the VPS and fill in real values.
# Never commit .env.production itself — only this template.
# =====================================================================

# --- Database (internal Docker network) -----------------------------
DATABASE_URL=postgresql://shtetl:YOUR_PASSWORD@shtetl-postgres:5432/shtetl_db

# --- NextAuth v5 ----------------------------------------------------
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://shtetlatlas.org
AUTH_URL=https://shtetlatlas.org
# AUTH_TRUST_HOST is set in docker-compose.production.yml (not a secret)

# --- CLI / MapStudio API key (Bearer token for /api/cli/*) ----------
SHT_API_KEY=generate-with-openssl-rand-hex-32

# --- Cloudflare R2 Storage -----------------------------------------
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_BASE_URL=https://pub-your-bucket.r2.dev

# --- OpenAI (for /api/translate LLM authoring helper) --------------
OPENAI_API_KEY=your-openai-api-key

# --- Cloudflare Turnstile ------------------------------------------
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# --- Contact form SMTP ---------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=postmaster@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Shtetl Atlas <no-reply@shtetlatlas.org>"

# =====================================================================
# Dev env vars for docker-compose.yml (postgres-only, local dev).
# Put these in app/.env (which is gitignored) when running locally.
# =====================================================================
# POSTGRES_USER=shtetl
# POSTGRES_PASSWORD=dev_password_change_me
# POSTGRES_DB=shtetl_db
