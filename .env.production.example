# Database (internal Docker network - no external access)
DATABASE_URL=postgresql://shnyor:YOUR_PASSWORD@postgres-db:5432/shtetl_db

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://YOUR_SERVER_IP

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_BASE_URL=https://pub-your-bucket.r2.dev

# OpenAI (for translation feature)
OPENAI_API_KEY=your-openai-api-key

# Optional: Public-facing API URLs
# NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3000
# NEXT_PUBLIC_ADMIN_API_URL=http://YOUR_SERVER_IP:3001
